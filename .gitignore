#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Unblurred source screenshots (only the redacted screenshot.png is checked in)
/docs/screenshots/raw.png

# Per-machine Claude Code config
.claude/

# One-time CI secrets bundle written by scripts/collect_macos_ci_secrets.sh.
# This file carries a base64 Developer ID .p12 and an App Store Connect
# .p8 private key — never commit it.
macos_ci_secrets.env
